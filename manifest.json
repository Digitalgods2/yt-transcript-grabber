{
  "manifest_version": 3,
  "name": "YT Transcript Grabber",
  "short_name": "Transcript Grabber",
  "version": "1.0.0",
  "description": "One click to copy and download the transcript of the YouTube video you're watching.",
  "permissions": ["scripting", "activeTab", "downloads"],
  "host_permissions": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
  "action": {
    "default_title": "Grab transcript",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
